# Single deployment defaults for demo and single-host use.
# Use with:
#   scripts/server-run.sh up
#   scripts/cloud-smoke-test.sh
#
# `scripts/bootstrap-ubuntu-docker.sh` reads these from `.env` when present.
CVECT_BOOTSTRAP_UBUNTU_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
CVECT_BOOTSTRAP_DOCKER_APT_REPO=https://mirrors.aliyun.com/docker-ce/linux/ubuntu
CVECT_BOOTSTRAP_DOCKER_GPG_URL=https://mirrors.aliyun.com/docker-ce/linux/ubuntu/gpg

CVECT_HTTP_PORT=8088

CVECT_BASIC_AUTH_ENABLED=true
CVECT_BASIC_AUTH_USERNAME=demo
CVECT_BASIC_AUTH_PASSWORD=demo123

CVECT_POSTGRES_DB=cvect
CVECT_POSTGRES_USER=postgres
CVECT_POSTGRES_PASSWORD=cvect-demo

CVECT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
CVECT_EMBEDDING_SERVICE_URL=http://qwen:8001/embed
CVECT_EMBEDDING_API_FORMAT=auto
CVECT_EMBEDDING_HEALTH_URL=http://qwen:8001/health
CVECT_EMBEDDING_DEVICE=cpu
CVECT_TORCH_DTYPE=auto
# 2C4G 同机部署建议保持 1 线程、单请求并发。
CVECT_TORCH_NUM_THREADS=1
CVECT_TORCH_NUM_INTEROP_THREADS=1
CVECT_EMBEDDING_BATCH_SIZE=1
CVECT_EMBEDDING_MAX_CONCURRENT_REQUESTS=1
CVECT_EMBEDDING_MAX_INPUT_LENGTH=1024
CVECT_EMBEDDING_IDLE_UNLOAD_SECONDS=900
CVECT_EMBEDDING_IDLE_CHECK_INTERVAL_SECONDS=30
CVECT_EMBEDDING_TIMEOUT_SECONDS=120
CVECT_CHUNK_MAX_LENGTH=1000
CVECT_CHUNK_OVERLAP=100
CVECT_PRELOAD_MODELS=false
CVECT_MALLOC_ARENA_MAX=2
CVECT_HF_CACHE_DIR=./.runtime/huggingface
CVECT_HF_CACHE_ARCHIVE=./.artifacts/qwen-hf-cache.tgz
CVECT_HF_ENDPOINT=https://huggingface.co
CVECT_HF_HUB_OFFLINE=true
CVECT_HF_LOCAL_FILES_ONLY=true
CVECT_HF_HUB_DISABLE_XET=false
# 本地预下载时可通过代理访问 Hugging Face；服务器默认走离线 cache。
CVECT_HTTP_PROXY=
CVECT_HTTPS_PROXY=
CVECT_NO_PROXY=127.0.0.1,localhost,postgres,qwen,backend,frontend
# 先在本地下载，再把 `CVECT_HF_CACHE_ARCHIVE` 或 `CVECT_HF_CACHE_DIR` 传到服务器：
#   scripts/qwen-offline-cache.sh prefetch
#   scripts/qwen-offline-cache.sh pack
#   scp ${CVECT_HF_CACHE_ARCHIVE} <server>:/path/
#   服务器上执行: scripts/qwen-offline-cache.sh unpack /path/qwen-hf-cache.tgz
# 如果改用外部 OpenAI-compatible embedding 服务，可改这几项：
# CVECT_EMBEDDING_SERVICE_URL=http://<embedding-host>:<port>/v1/embeddings
# CVECT_EMBEDDING_API_FORMAT=openai
# CVECT_EMBEDDING_HEALTH_URL=http://<embedding-host>:<port>/health
# 如果改用 llama.cpp / GGUF 原生 embedding 服务，可改这几项：
# CVECT_EMBEDDING_SERVICE_URL=http://<embedding-host>:<port>/embedding
# CVECT_EMBEDDING_API_FORMAT=llama_cpp
# CVECT_EMBEDDING_HEALTH_URL=http://<embedding-host>:<port>/health
# 本地预下载时如 huggingface.co 不可达，可改这里：
# CVECT_HF_ENDPOINT=https://<your-hf-proxy>
# 本地预下载时如 Xet 下载链路不通：
# CVECT_HF_HUB_DISABLE_XET=true

CVECT_SHOW_SQL=false
CVECT_CACHE_ENABLED=true
CVECT_VECTOR_ENABLED=true
CVECT_VECTOR_INGEST_WORKER_ENABLED=true
CVECT_VECTOR_MAX_CONCURRENT_WRITES=1
CVECT_VECTOR_INGEST_WORKER_CLAIM_BATCH_SIZE=1
CVECT_VECTOR_INGEST_WORKER_MAX_POOL=1
JAVA_OPTS=-Xms384m -Xmx1024m

# Preferred path: sync all required images to your own ACR/TCR/SWR registry,
# then point these image vars to your private copies.
# Example:
# CVECT_POSTGRES_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/pgvector:pg17
# CVECT_MAVEN_BUILD_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/maven:3.9.9-eclipse-temurin-17
# CVECT_JAVA_RUNTIME_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/eclipse-temurin:17-jre-jammy
# CVECT_NODE_BUILD_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/node:20-alpine
# CVECT_NGINX_RUNTIME_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/nginx:1.27-alpine
# CVECT_PYTHON_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/<namespace>/python:3.10-slim

# Quick path for Docker Hub images: DaoCloud mirror prefix.
CVECT_POSTGRES_IMAGE=m.daocloud.io/docker.io/pgvector/pgvector:pg17
CVECT_MAVEN_BUILD_IMAGE=m.daocloud.io/docker.io/library/maven:3.9.9-eclipse-temurin-17
CVECT_JAVA_RUNTIME_IMAGE=m.daocloud.io/docker.io/library/eclipse-temurin:17-jre-jammy
CVECT_NODE_BUILD_IMAGE=m.daocloud.io/docker.io/library/node:20-alpine
CVECT_NGINX_RUNTIME_IMAGE=m.daocloud.io/docker.io/library/nginx:1.27-alpine
CVECT_PYTHON_BASE_IMAGE=m.daocloud.io/docker.io/library/python:3.10-slim
# Domestic package mirrors
CVECT_MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
CVECT_NPM_REGISTRY=https://registry.npmmirror.com
CVECT_PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
CVECT_PIP_TRUSTED_HOST=mirrors.tuna.tsinghua.edu.cn
CVECT_TORCH_PACKAGE=torch==2.10.0+cpu
CVECT_TORCH_WHEEL_INDEX_URL=https://download.pytorch.org/whl/cpu
CVECT_TORCH_WHEEL_TRUSTED_HOST=download.pytorch.org
CVECT_DEBIAN_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
CVECT_UBUNTU_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
CVECT_ALPINE_APK_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/alpine
