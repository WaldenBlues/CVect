# =========================
# CVect project .gitignore
# Track source, config, docs, and test fixtures.
# Ignore only local/runtime/generated artifacts.
# =========================

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- Editors ----------
.idea/
.vscode/
*.iml

# ---------- Generic temp/log ----------
*.log
*.tmp
*.swp
*.bak
*.orig

# ---------- Python ----------
__pycache__/
*.py[cod]
.env
.env.*
!.env.example
.venv/
venv/
.envrc
.ipynb_checkpoints/

# ---------- Local env tools ----------
miniconda3/
envs/

# ---------- Java / Maven / Gradle ----------
**/target/
**/build/
.gradle/
.m2/wrapper/dists/

# ---------- Backend runtime data ----------
backend/cvect/storage/

# ---------- Frontend artifacts ----------
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/.env

# ---------- Local run artifacts ----------
.run/
.runtime/
.artifacts/

# ---------- Qwen local/generated artifacts ----------
Qwen/.venv/
Qwen/.hf_cache/
Qwen/.service_logs/
Qwen/.datagen_work/
Qwen/.datagen_logs/
Qwen/generated_resumes_1000/

# ---------- Local scripts ----------
scripts/*.local.sh

# ---------- Docs build output ----------
docs/_build/
