# =========================
# CVect project .gitignore
# Track source, config, docs, and test fixtures.
# Ignore only local/runtime/generated artifacts.
# =========================

# ---------- OS ----------
.DS_Store
Thumbs.db
*:Zone.Identifier

# ---------- Editors ----------
.idea/
.vscode/
*.iml

# ---------- Generic temp/log ----------
*.log
*.tmp
*.swp
*.bak
*.orig

# ---------- Python ----------
__pycache__/
*.py[cod]
.env.local
.env.*.local
.venv/
venv/
.envrc
.ipynb_checkpoints/

# ---------- Local env tools ----------
miniconda3/
envs/

# ---------- Java / Maven / Gradle ----------
.m2/
backend/cvect/.m2-ci/
**/target/
**/build/
.gradle/

# ---------- Backend runtime data ----------
backend/cvect/storage/

# ---------- Frontend artifacts ----------
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/.env

# ---------- Local run artifacts ----------
.run/
.runtime/
.artifacts/
.ralph/
.codex
tmp/

# ---------- Qwen local/generated artifacts ----------
Qwen/.venv/
Qwen/.hf_cache/
Qwen/.service_logs/
Qwen/.datagen_work/
Qwen/.datagen_logs/
Qwen/generated_resumes_1000/

# ---------- Local scripts ----------
scripts/*.local.sh

# ---------- Docs build output ----------
docs/_build/
*.docx
PLANS.md
