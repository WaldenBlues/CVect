# Embedding host deployment defaults.
# Use with:
#   scripts/embedding-run.sh up
#   scripts/qwen-offline-cache.sh prefetch

CVECT_BOOTSTRAP_UBUNTU_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
CVECT_BOOTSTRAP_DOCKER_APT_REPO=https://mirrors.aliyun.com/docker-ce/linux/ubuntu
CVECT_BOOTSTRAP_DOCKER_GPG_URL=https://mirrors.aliyun.com/docker-ce/linux/ubuntu/gpg

CVECT_EMBEDDING_PUBLIC_PORT=8001
CVECT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
CVECT_EMBEDDING_DEVICE=cpu
CVECT_TORCH_DTYPE=auto
CVECT_TORCH_NUM_THREADS=1
CVECT_TORCH_NUM_INTEROP_THREADS=1
CVECT_EMBEDDING_BATCH_SIZE=1
CVECT_EMBEDDING_MAX_CONCURRENT_REQUESTS=1
CVECT_EMBEDDING_MAX_INPUT_LENGTH=1024
CVECT_EMBEDDING_IDLE_UNLOAD_SECONDS=900
CVECT_EMBEDDING_IDLE_CHECK_INTERVAL_SECONDS=30
CVECT_PRELOAD_MODELS=false
CVECT_MALLOC_ARENA_MAX=2

CVECT_HF_CACHE_DIR=./.runtime/huggingface
CVECT_HF_CACHE_ARCHIVE=./.artifacts/qwen-hf-cache.tgz
CVECT_HF_ENDPOINT=https://huggingface.co
CVECT_HF_HUB_OFFLINE=true
CVECT_HF_LOCAL_FILES_ONLY=true
CVECT_HF_HUB_DISABLE_XET=false
CVECT_HTTP_PROXY=
CVECT_HTTPS_PROXY=
CVECT_NO_PROXY=127.0.0.1,localhost
CVECT_CORS_ALLOW_ORIGINS=

CVECT_PYTHON_BASE_IMAGE=m.daocloud.io/docker.io/library/python:3.10-slim
CVECT_PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
CVECT_PIP_TRUSTED_HOST=mirrors.tuna.tsinghua.edu.cn
CVECT_TORCH_PACKAGE=torch==2.10.0
CVECT_TORCH_WHEEL_INDEX_URL=https://download.pytorch.org/whl/cpu
CVECT_TORCH_WHEEL_TRUSTED_HOST=download.pytorch.org
CVECT_DEBIAN_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian
