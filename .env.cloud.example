# Public HTTP port exposed by the frontend nginx container.
# Optional bootstrap mirrors for `sudo -E bash scripts/bootstrap-ubuntu-docker.sh`:
# export CVECT_BOOTSTRAP_UBUNTU_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
# export CVECT_BOOTSTRAP_DOCKER_APT_REPO=https://mirrors.aliyun.com/docker-ce/linux/ubuntu
# export CVECT_BOOTSTRAP_DOCKER_GPG_URL=https://mirrors.aliyun.com/docker-ce/linux/ubuntu/gpg

CVECT_HTTP_PORT=80
CVECT_BASIC_AUTH_ENABLED=true
CVECT_BASIC_AUTH_USERNAME=admin
CVECT_BASIC_AUTH_PASSWORD=change-me-now

CVECT_POSTGRES_DB=cvect
CVECT_POSTGRES_USER=postgres
CVECT_POSTGRES_PASSWORD=change-me

CVECT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
CVECT_GENERATION_MODEL=Qwen/Qwen3-0.6B
CVECT_EMBEDDING_DEVICE=cpu
CVECT_TORCH_DTYPE=auto
CVECT_EMBEDDING_BATCH_SIZE=32
CVECT_EMBEDDING_MAX_INPUT_LENGTH=8192
CVECT_MAX_NEW_TOKENS_DEFAULT=256
CVECT_PRELOAD_MODELS=false
CVECT_READINESS_REQUIRE_GENERATION=false

CVECT_SHOW_SQL=false
CVECT_CACHE_ENABLED=true
JAVA_OPTS=-Xms512m -Xmx1536m
